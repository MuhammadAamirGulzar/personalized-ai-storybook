---
title: MyAIStorybook FYP-2 — Class Diagram
---
classDiagram
    class BaseAgent {
        <<abstract>>
        -logger Logger
        +process(input dict) dict
    }

    class PromptAgent {
        -min_length int
        -max_length int
        +process_prompt(prompt str) tuple
        +classify_prompt(prompt str) str
        +enhance_prompt(prompt str) str
    }

    class WriterAgent {
        -model str
        -max_retries int
        +generate_story(prompt str, genre str, style str, length str) dict
        -_call_ollama(prompt str) str
        -_parse_json(response str) dict
    }

    class ReviewerAgent {
        +review_story(story dict) dict
        -_check_coherence(story dict) bool
        -_check_age_appropriateness(story dict) bool
    }

    class EditorAgent {
        +edit_story(story dict) tuple
        +export_pdf(story dict, filename str) str
        -_draw_cover_page(canvas, story)
        -_draw_scene_page(canvas, scene, idx, total)
        -_register_fonts() tuple
    }

    class DirectorAgent {
        -writer WriterAgent
        -reviewer ReviewerAgent
        -editor EditorAgent
        +create_story(prompt str, genre str, style str, length str) dict
    }

    class StoryAgent {
        -director DirectorAgent
        +generate(prompt str, generate_images bool, use_personalized bool, user_photo bytes) dict
    }

    class ImageAgent {
        -webui_url str
        -steps int
        +generate_image(description str, style str) str
        -_txt2img(prompt str) str
        -_img2img(image str, prompt str) str
    }

    class PersonalizedImageAgent {
        -ip_adapter_model str
        -face_embedding tensor
        +generate_image(description str, user_photo bytes) str
        -_encode_face(photo bytes) tensor
    }

    class ChatbotAgent {
        -story_context dict
        -character str
        +chat(message str, session_id str) str
    }

    class IdeaWorkshopAgent {
        -llm_chain LLMChain
        -memory ConversationBufferMemory
        +chat(session_id str, message str) dict
        -_determine_ready(session dict) bool
    }

    class TTSManager {
        -$_instance TTSManager
        -models_dir str
        -audio_dir str
        -voices dict
        +generate_audio(text str, story_id int, scene_number int, voice str) str
        +$get_tts_manager() TTSManager
    }

    class WhisperSTTManager {
        -$_instance WhisperSTTManager
        -model_size str
        -_model Whisper
        +load_model() Whisper
        +transcribe_audio(file_path str, language str) dict
        +transcribe_audio_bytes(audio bytes) dict
        +$get_stt_manager() WhisperSTTManager
    }

    class EvaluationManager {
        -$_instance EvaluationManager
        -save_dir str
        +evaluate_story(story_id int, story dict, images list, mode str) dict
        -_evaluate_image_text_alignment() int
        -_evaluate_visual_consistency() int
        -_evaluate_text_coherence() int
        -_evaluate_readability() int
        -_evaluate_story_structure() int
        -_evaluate_character_consistency() int
        +$get_evaluation_manager() EvaluationManager
    }

    class ContentSafety {
        -blocked_keywords list
        +is_safe(text str) bool
        +get_negative_prompts() str
    }

    class OllamaManager {
        +pause_ollama() bool
        +resume_ollama() bool
        +is_running() bool
    }

    class User {
        -id int
        -username str
        -email str
        -hashed_password str
        -created_at datetime
    }

    class Story {
        -id int
        -user_id int
        -title str
        -story_json JSON
        -pdf_path str
        -mode str
        -created_at datetime
    }

    class WorkshopSession {
        -id int
        -user_id int
        -mode str
        -status str
    }

    class WorkshopMessage {
        -id int
        -session_id int
        -role str
        -content str
        -metadata JSON
    }

    BaseAgent <|-- PromptAgent
    BaseAgent <|-- WriterAgent
    BaseAgent <|-- ReviewerAgent
    BaseAgent <|-- EditorAgent
    BaseAgent <|-- ImageAgent
    BaseAgent <|-- ChatbotAgent
    BaseAgent <|-- IdeaWorkshopAgent
    ImageAgent <|-- PersonalizedImageAgent

    DirectorAgent o-- WriterAgent : coordinates
    DirectorAgent o-- ReviewerAgent : coordinates
    DirectorAgent o-- EditorAgent : coordinates
    DirectorAgent o-- ImageAgent : uses
    DirectorAgent ..> PersonalizedImageAgent : uses if personalized
    DirectorAgent o-- PromptAgent : validates with

    StoryAgent --> DirectorAgent : delegates to
    StoryAgent --> OllamaManager : manages GPU via
    StoryAgent ..> EvaluationManager : triggers async

    ChatbotAgent ..> Story : reads context
    IdeaWorkshopAgent --> WorkshopSession : manages
    IdeaWorkshopAgent --> WorkshopMessage : stores

    User "1" --> "many" Story : creates
    User "1" --> "many" WorkshopSession : participates
    WorkshopSession "1" --> "many" WorkshopMessage : contains
