@startuml
skinparam componentStyle rectangle
skinparam packageBackgroundColor #EEF5FF
skinparam packageBorderColor #1A5276
skinparam componentBackgroundColor #DDEEFF
skinparam componentBorderColor #154360
skinparam componentFontSize 12
skinparam packageFontSize 13
skinparam arrowColor #2C3E50
skinparam databaseBackgroundColor #FDEBD0
skinparam databaseBorderColor #CA6F1E
skinparam noteBackgroundColor #FFFACD
skinparam noteBorderColor #B7950B
skinparam backgroundColor #FAFAFA

title MyAIStorybook FYP-2 — System Architecture Diagram\n(Layered Architecture with Component View)

'=============================================================
' LAYER 1: PRESENTATION
'=============================================================
package "Presentation Layer\n(Client — Next.js / TypeScript)" as L1 #EAF2FB {
    component "[Story Generation UI]\nText/Voice Input\nMode Selector\nGenre/Style/Length Dropdowns" as UI_GEN <<component>>
    component "[Open-Book Viewer]\nPage-Flip Navigation\nLeft: Illustration\nRight: Story Text" as UI_BOOK <<component>>
    component "[Audio Controls]\nPlay / Pause\nVoice Selector\nTTS Playback" as UI_AUDIO <<component>>
    component "[Character Chat]\nCharacter Selector\nMessage Input\nResponse Display" as UI_CHAT <<component>>
    component "[Idea Workshop]\nMulti-turn Dialog\nRequirements Form\nGenerate Button" as UI_WORKSHOP <<component>>
    component "[Auth UI]\nLogin / Register\nJWT Token Storage" as UI_AUTH <<component>>
}

'=============================================================
' LAYER 2: APPLICATION (API Gateway)
'=============================================================
package "Application Layer\n(FastAPI — REST API Server)" as L2 #EBF5EB {
    component "[POST /api/generate]\nStory Generation\nEndpoint" as API_GEN <<component>>
    component "[POST /api/tts]\nText-to-Speech\nEndpoint" as API_TTS <<component>>
    component "[POST /api/stt]\nSpeech-to-Text\nEndpoint" as API_STT <<component>>
    component "[POST /api/chat]\nCharacter Chat\nEndpoint" as API_CHAT <<component>>
    component "[POST /api/workshop]\nIdea Workshop\nEndpoint" as API_WSHOP <<component>>
    component "[POST /api/check-face]\nFace Detection\nEndpoint" as API_FACE <<component>>
    component "[GET /api/stories]\nStory History\nEndpoint" as API_HIST <<component>>
    component "[Auth Routes]\nJWT Auth\nUser CRUD" as API_AUTH <<component>>
    component "[CORS + Auth\nMiddleware]" as MIDDLEWARE <<component>>
}

'=============================================================
' LAYER 3: BUSINESS LOGIC (Multi-Agent System)
'=============================================================
package "Business Logic Layer\n(Multi-Agent Pipeline)" as L3 #FEF9E7 {

    package "Story Generation Pipeline" as L3_STORY {
        component "[PromptAgent]\nValidation\nClassification\nEnhancement" as PA <<component>>
        component "[DirectorAgent]\nPipeline\nOrchestration" as DA <<component>>
        component "[WriterAgent]\nStory Draft\nJSON Generation" as WA <<component>>
        component "[ReviewerAgent]\nCoherence Check\nAge Check" as RA <<component>>
        component "[EditorAgent]\nFinal Polish\nPDF Export" as EA <<component>>
    }

    package "Image Generation" as L3_IMAGE {
        component "[ImageAgent]\nStandard\nSD Generation" as IA <<component>>
        component "[PersonalizedImageAgent]\nIP-Adapter FaceID\nCharacter Consistency" as PIA <<component>>
    }

    package "Interactive Features" as L3_INTERACT {
        component "[ChatbotAgent]\nCharacter Chat\nStory Context" as CA <<component>>
        component "[IdeaWorkshopAgent]\nLangChain\nMulti-turn Dialog" as IWA <<component>>
    }

    package "Quality & Utility" as L3_UTIL {
        component "[EvaluationAgent]\nAsync Subprocess\nMetrics Runner" as EVA <<component>>
        component "[ContentSafety]\nBlocked Keywords\nPrompt Filter" as CS <<component>>
        component "[OllamaManager]\nGPU Memory\nPause/Resume" as OM <<component>>
    }
}

'=============================================================
' LAYER 4: AI/ML INFERENCE
'=============================================================
package "AI / ML Layer\n(Local Inference — Offline)" as L4 #FDF2F8 {
    component "[Ollama Server]\nllama3.1:8b-instruct\nq4_K_M" as OLLAMA <<component>>
    component "[Stable Diffusion WebUI]\nRealistic Vision\nDPM++ 2M Karras\ntxt2img + img2img" as SDWUI <<component>>
    component "[Piper TTS]\nONNX Models\nen_US-ryan / lessac" as PIPER <<component>>
    component "[OpenAI Whisper]\nBase Model\nOffline STT" as WHISPER <<component>>
    component "[CLIP ViT-B/32]\nImage-Text Alignment\nVisual Consistency" as CLIP <<component>>
    component "[Sentence Transformers]\nText Coherence\nEmbeddings" as SBERT <<component>>
    component "[InsightFace]\nFace Embeddings\nCharacter Consistency" as IFACE <<component>>
}

'=============================================================
' LAYER 5: DATA / PERSISTENCE
'=============================================================
package "Data Layer\n(Hybrid Storage)" as L5 #FEF5E7 {
    database "PostgreSQL\n(SQLAlchemy ORM)\nUsers, Stories,\nChatSessions,\nWorkshopSessions" as DB <<database>>

    package "File System\n(generated/)" as FS {
        component "[images/]\nPNG Illustrations" as FS_IMG <<component>>
        component "[audio/]\nWAV Narrations\n(TTS Cache)" as FS_AUD <<component>>
        component "[exports/]\nStyled PDFs" as FS_PDF <<component>>
        component "[evaluations/]\nMetrics JSON" as FS_EVAL <<component>>
        component "[stories/]\nStory JSON\nObjects" as FS_STR <<component>>
    }
}

'=============================================================
' INTER-LAYER DEPENDENCIES (top-down flow)
'=============================================================
' Presentation → Application
L1 -down-> L2 : HTTP REST\n(fetch/axios)

' Application → Business Logic
L2 -down-> L3 : method calls\n(Python imports)

' Business Logic → AI/ML
DA -down-> OLLAMA : Ollama API\nHTTP (localhost:11434)
IA -down-> SDWUI : WebUI API\nHTTP (localhost:7860)
PIA -down-> SDWUI : WebUI API +\nIP-Adapter weights
PA -down-> CS : prompt safety check
EA -down-> PIPER : subprocess CLI
EVA -down-> CLIP : model inference
EVA -down-> SBERT : model inference
EVA -down-> IFACE : model inference
API_STT -down-> WHISPER : model.transcribe()
OM -down-> OLLAMA : process management\n(pause/resume)

' Business Logic → Data Layer
DA -down-> FS_STR : save story JSON
EA -down-> FS_PDF : save PDF
IA -down-> FS_IMG : save PNG
PIA -down-> FS_IMG : save PNG
EVA -down-> FS_EVAL : save metrics JSON
API_TTS -down-> FS_AUD : read/write WAV cache
L2 -down-> DB : SQLAlchemy ORM\n(CRUD operations)

@enduml
