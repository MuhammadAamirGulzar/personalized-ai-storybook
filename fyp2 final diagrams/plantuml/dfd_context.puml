@startuml
!define DFD

skinparam rectangle {
    BackgroundColor LightBlue
    BorderColor DarkBlue
    FontSize 12
}
skinparam database {
    BackgroundColor LightGoldenRodYellow
    BorderColor DarkOrange
    FontSize 12
}
skinparam actor {
    BackgroundColor LightGreen
    BorderColor DarkGreen
    FontSize 12
}

title MyAIStorybook FYP-2 — Context Diagram (DFD Level 0)

actor User as U
rectangle "MyAIStorybook\nSystem" as SYS #LightCyan
actor "Ollama Server\n(Local LLM)" as OLLAMA
actor "Stable Diffusion\nWebUI (Local)" as SDWUI
database "PostgreSQL\nDatabase" as DB

' User flows
U --> SYS : Text Prompt /\nVoice Audio /\nReference Photo
SYS --> U : Story JSON /\nOpen-Book UI /\nAudio (WAV) /\nPDF Download /\nEvaluation Metrics

' Backend AI services
SYS --> OLLAMA : Enhanced Prompt\n(Story generation request)
OLLAMA --> SYS : Story JSON\n(LLM response)

SYS --> SDWUI : Scene Description\n+ IP-Adapter Embedding
SDWUI --> SYS : Generated Images\n(PNG, 512x512→768x768)

' Database
SYS --> DB : User Data /\nStory Records /\nSession History /\nWorkshop Data
DB --> SYS : Stored Stories /\nUser Auth /\nConversation History

@enduml
