@startuml
skinparam sequenceMessageAlign left
skinparam sequenceArrowThickness 2
skinparam participantFontSize 13
skinparam backgroundColor #FEFEFE
skinparam sequenceParticipantBackgroundColor #DDEEFF
skinparam sequenceActorBackgroundColor #FFFACD

title System Sequence Diagram (SSD): UC6 — Chat with Story Character

actor ":User" as U
participant ":System" as S

note over U, S #LightYellow
  Use Case: UC6 — Chat with Story Character
  Primary Actor: Registered User
  Precondition: User has a generated story open; story contains characters.
  The system is treated as a BLACK BOX.
end note

U -> S : openCharacterChat(storyId: int)
S --> U : characterList(characters: String[])
note left: Returns list of character names\nfrom the story

U -> S : selectCharacter(storyId: int, characterName: String)
S --> U : chatSessionReady(character: String, greeting: String)
note left: Character greets user in-character\nbased on story context

loop [multi-turn conversation]
    U -> S : sendMessage(storyId: int, characterName: String,\n   userMessage: String)
    note right: e.g. sendMessage(42, "Luna",\n"What was the hardest part of your journey?")
    S --> U : characterResponse(response: String, character: String)
    note left: LLM responds in-character\nusing full story context
end

U -> S : closeChat()
S --> U : chatClosed

@enduml
