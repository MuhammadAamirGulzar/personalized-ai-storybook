@startuml
skinparam sequenceMessageAlign left
skinparam sequenceArrowThickness 2
skinparam participantFontSize 13
skinparam backgroundColor #FEFEFE
skinparam sequenceParticipantBackgroundColor #DDEEFF
skinparam sequenceActorBackgroundColor #FFFACD

title System Sequence Diagram (SSD): UC3 — Listen to Story Narration (TTS)

actor ":User" as U
participant ":System" as S

note over U, S #LightYellow
  Use Case: UC3 — Listen to Story Narration
  Primary Actor: Registered User
  Precondition: User has a generated story open in the UI.
  The system is treated as a BLACK BOX.
end note

U -> S : openStory(storyId: int)
S --> U : storyData(title: String, scenes: Scene[], pdfPath: String)

U -> S : selectVoice(voice: "male" | "female")
S --> U : voiceSelected(voice: String)

loop [for each scene page the user navigates to]

    U -> S : requestNarration(storyId: int, sceneNumber: int, voice: String)
    note right: e.g. requestNarration(42, 1, "female")

    alt [audio already cached]
        S --> U : audioReady(audioPath: String, cached: true)
    else [audio not cached — generate]
        S --> U : audioGenerating(sceneNumber: int)
        S --> U : audioReady(audioPath: String, cached: false)
    end

    U -> S : playAudio(audioPath: String)
    S --> U : audioPlaying(duration: float)

    opt [user pauses]
        U -> S : pauseAudio()
        S --> U : audioPaused(position: float)
    end

    opt [user resumes]
        U -> S : resumeAudio(position: float)
        S --> U : audioPlaying(duration: float)
    end

end

@enduml
