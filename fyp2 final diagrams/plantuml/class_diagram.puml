@startuml
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam classBackgroundColor LightCyan
skinparam classBorderColor DarkBlue
skinparam arrowColor DarkSlateGray

title MyAIStorybook FYP-2 — Class Diagram

' ============================================================
' Abstract Base
' ============================================================
abstract class BaseAgent {
    - logger: Logger
    + process(input: dict): dict
}

' ============================================================
' Story Generation Agents
' ============================================================
class PromptAgent {
    - min_length: int = 5
    - max_length: int = 500
    + process_prompt(prompt: str): tuple
    + classify_prompt(prompt: str): str
    + enhance_prompt(prompt: str): str
    - _validate_length(prompt: str): bool
}

class WriterAgent {
    - model: str = "llama3.1:8b-instruct-q4_K_M"
    - max_retries: int = 2
    + generate_story(prompt: str, genre: str,\n  style: str, length: str): dict
    - _call_ollama(prompt: str): str
    - _parse_json(response: str): dict
}

class ReviewerAgent {
    + review_story(story: dict): dict
    - _check_coherence(story: dict): bool
    - _check_age_appropriateness(story: dict): bool
    - _validate_scene_count(story: dict): bool
}

class EditorAgent {
    + edit_story(story: dict): tuple
    + export_pdf(story: dict,\n  filename: str): str
    - _draw_cover_page(canvas, story, images_dir)
    - _draw_scene_page(canvas, scene, idx, total)
    - _draw_leather_bg(canvas)
    - _register_fonts(): tuple
}

class DirectorAgent {
    - writer: WriterAgent
    - reviewer: ReviewerAgent
    - editor: EditorAgent
    + create_story(prompt: str,\n  genre: str, style: str,\n  length: str): dict
}

class StoryAgent {
    - director: DirectorAgent
    + generate(prompt: str,\n  generate_images: bool,\n  use_personalized: bool,\n  user_photo: bytes): dict
}

' ============================================================
' Image Agents
' ============================================================
class ImageAgent {
    - webui_url: str
    - sampler: str = "DPM++ 2M Karras"
    - steps: int = 25
    + generate_image(description: str,\n  style: str): str
    - _txt2img(prompt: str): str
    - _img2img(image: str, prompt: str): str
}

class PersonalizedImageAgent {
    - ip_adapter_model: str
    - face_embedding: tensor
    + generate_image(description: str,\n  user_photo: bytes): str
    - _load_ip_adapter(): void
    - _encode_face(photo: bytes): tensor
}

' ============================================================
' Chatbot & Workshop
' ============================================================
class ChatbotAgent {
    - story_context: dict
    - character: str
    + chat(message: str,\n  session_id: str): str
    - _build_character_prompt(msg: str): str
}

class IdeaWorkshopAgent {
    - llm_chain: LLMChain
    - memory: ConversationBufferMemory
    + chat(session_id: str,\n  message: str): dict
    - _determine_ready(session: dict): bool
    - _collect_requirements(msg: str): dict
}

' ============================================================
' Utility Managers (Singletons)
' ============================================================
class TTSManager {
    - {static} _instance: TTSManager
    - models_dir: str
    - audio_dir: str
    - voices: dict
    + generate_audio(text: str,\n  story_id: int,\n  scene_number: int,\n  voice: str): str
    - _build_piper_command(model, text, output): str
    + {static} get_tts_manager(): TTSManager
}

class WhisperSTTManager {
    - {static} _instance: WhisperSTTManager
    - model_size: str = "base"
    - _model: Whisper
    + load_model(): Whisper
    + transcribe_audio(file_path: str,\n  language: str): dict
    + transcribe_audio_bytes(audio: bytes): dict
    - {static} _read_wav_to_float32(wav: bytes): tuple
    - {static} _resample(audio: ndarray,\n  orig_sr: int, target_sr: int): ndarray
    + {static} get_stt_manager(): WhisperSTTManager
}

class EvaluationManager {
    - {static} _instance: EvaluationManager
    - save_dir: str
    - _clip_model: CLIPModel
    - _sentence_model: SentenceTransformer
    - _face_app: FaceAnalysis
    + evaluate_story(story_id: int,\n  story: dict, images: list,\n  mode: str): dict
    - _evaluate_image_text_alignment(): int
    - _evaluate_visual_consistency(): int
    - _evaluate_text_coherence(): int
    - _evaluate_readability(): int
    - _evaluate_story_structure(): int
    - _evaluate_character_consistency(): int
    + save_evaluation(story_id: int,\n  results: dict): void
    + {static} get_evaluation_manager(): EvaluationManager
}

class ContentSafety {
    - blocked_keywords: list
    - warning_keywords: list
    + is_safe(text: str): bool
    + enhance_with_safety(prompt: str): str
    + get_negative_prompts(): str
}

class OllamaManager {
    + pause_ollama(): bool
    + resume_ollama(): bool
    + is_running(): bool
}

' ============================================================
' Data Models (DB)
' ============================================================
class User {
    - id: int
    - username: str
    - email: str
    - hashed_password: str
    - created_at: datetime
}

class Story {
    - id: int
    - user_id: int
    - title: str
    - story_json: JSON
    - pdf_path: str
    - mode: str
    - created_at: datetime
}

class WorkshopSession {
    - id: int
    - user_id: int
    - mode: str
    - status: str
    - created_at: datetime
}

class WorkshopMessage {
    - id: int
    - session_id: int
    - role: str
    - content: str
    - metadata: JSON
    - timestamp: datetime
}

' ============================================================
' Relationships
' ============================================================
BaseAgent <|-- PromptAgent
BaseAgent <|-- WriterAgent
BaseAgent <|-- ReviewerAgent
BaseAgent <|-- EditorAgent
BaseAgent <|-- ImageAgent
BaseAgent <|-- ChatbotAgent
BaseAgent <|-- IdeaWorkshopAgent

ImageAgent <|-- PersonalizedImageAgent

DirectorAgent o-- WriterAgent : coordinates
DirectorAgent o-- ReviewerAgent : coordinates
DirectorAgent o-- EditorAgent : coordinates
DirectorAgent o-- ImageAgent : uses
DirectorAgent o-- PersonalizedImageAgent : uses (if personalized)
DirectorAgent o-- PromptAgent : validates with

StoryAgent --> DirectorAgent : delegates to
StoryAgent --> OllamaManager : manages GPU via
StoryAgent --> EvaluationManager : triggers async

ChatbotAgent ..> Story : reads context
IdeaWorkshopAgent --> WorkshopSession : manages
IdeaWorkshopAgent --> WorkshopMessage : stores

User "1" -- "many" Story : creates
User "1" -- "many" WorkshopSession : participates
WorkshopSession "1" -- "many" WorkshopMessage : contains

EditorAgent ..> TTSManager : audio paths via
@enduml
