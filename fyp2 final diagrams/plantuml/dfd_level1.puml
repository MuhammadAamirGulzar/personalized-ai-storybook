@startuml
skinparam rectangle {
    BackgroundColor LightBlue
    BorderColor DarkBlue
    FontSize 11
}
skinparam database {
    BackgroundColor LightGoldenRodYellow
    BorderColor DarkOrange
    FontSize 11
}
skinparam actorStyle awesome

title MyAIStorybook FYP-2 — Level 1 DFD

actor User as U #LightGreen

' Data stores
database "STORIES\n(generated/stories/)" as DS_STORIES
database "IMAGES\n(generated/images/)" as DS_IMAGES
database "AUDIO\n(generated/audio/)" as DS_AUDIO
database "EXPORTS\n(generated/exports/)" as DS_EXPORTS
database "EVALUATIONS\n(generated/evaluations/)" as DS_EVAL
database "DATABASE\n(PostgreSQL)" as DS_DB

' Processes
rectangle "1.0\nProcess\nUser Input" as P1 #LightSkyBlue
rectangle "2.0\nGenerate\nStory Text" as P2 #LightSkyBlue
rectangle "3.0\nGenerate\nIllustrations" as P3 #LightSkyBlue
rectangle "4.0\nSynthesize\nAudio (TTS)" as P4 #LightSkyBlue
rectangle "5.0\nExport\nPDF" as P5 #LightSkyBlue
rectangle "6.0\nEvaluate\nQuality" as P6 #LightSkyBlue

' User to processes
U --> P1 : Text Prompt /\nVoice Audio /\nReference Photo
P1 --> U : Transcribed Text\n(STT result)
P1 --> P2 : Enhanced Prompt /\nMode / Genre / Style

' Story generation
P2 <--> DS_DB : Read/Write User\n& Story records
P2 --> DS_STORIES : Story JSON
P2 --> P3 : Scene Descriptions +\nMode flag
P2 --> P5 : Story Data

' Image generation
P3 --> DS_IMAGES : PNG Image files
P3 --> P2 : Image paths

' Audio synthesis
U --> P4 : Play request\n(story_id, scene, voice)
P4 <--> DS_AUDIO : Read/Write WAV cache
P4 --> U : Audio WAV\n(relative path)
P2 --> P4 : Scene text data

' PDF export
P5 <-- DS_IMAGES : Scene PNG files
P5 --> DS_EXPORTS : Styled PDF
P5 --> U : PDF download link

' Evaluation
P6 <-- DS_STORIES : Story JSON
P6 <-- DS_IMAGES : Scene images
P6 --> DS_EVAL : Metrics JSON\n(0-100 scores)
P6 --> U : Evaluation\nresults display

' Story to evaluation
P2 --> P6 : Trigger evaluation\n(async, after generation)

@enduml
