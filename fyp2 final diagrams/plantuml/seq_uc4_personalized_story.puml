@startuml
skinparam sequenceMessageAlign left
skinparam sequenceArrowThickness 2
skinparam participantFontSize 12
skinparam backgroundColor #FEFEFE
skinparam sequenceLifeLineBorderColor #1A5276
skinparam sequenceParticipantBackgroundColor #D6EAF8
skinparam sequenceActorBackgroundColor #D6EAF8

title Sequence Diagram: UC4 — Generate Personalized Story

actor "User" as U
participant "Frontend" as FE
participant "FastAPI" as API
participant "PromptAgent" as PA
participant "DirectorAgent" as DA
participant "WriterAgent" as WA
participant "ReviewerAgent" as RA
participant "EditorAgent" as EA
participant "PersonalizedImageAgent" as PIA
participant "Database" as DB

U -> FE : select Personalized mode,\nupload reference photo
FE -> API : POST /api/check-face\n{photo: base64}
API --> FE : face_detected, confidence

alt face not detected
    FE --> U : warning — no face found
    U -> FE : choose Continue Anyway
end

U -> FE : enter prompt, select options,\nclick Generate
FE -> API : POST /api/generate\n{prompt, mode:"personalized",\nuser_photo, genre, style}

API -> PA : process_prompt(prompt)
PA --> API : enhanced_prompt, prompt_type

alt prompt_type = invalid
    API --> FE : 400 error
end

API -> DA : create_story(enhanced_prompt, genre, style)
DA -> WA : generate_story(prompt)
WA --> DA : story_draft
DA -> RA : review_story(story_draft)
RA --> DA : reviewed_story
DA -> EA : edit_story(reviewed_story)
EA --> DA : final_story, pdf_path

DA -> PIA : set_user_photo(reference_photo)
PIA -> PIA : encode face embedding\n(InsightFace)

loop for each scene
    PIA -> PIA : generate personalized image\n(IP-Adapter FaceID + SD WebUI)
    PIA --> DA : image_path
end

DA --> API : final_story with image paths
API -> DB : save story record
DB --> API : story_id
API --> FE : story JSON, story_id, pdf_path
FE --> U : display story with\ncharacter-consistent images

@enduml
