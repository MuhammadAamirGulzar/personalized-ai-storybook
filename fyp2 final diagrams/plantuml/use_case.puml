@startuml
!define ACTOR_STYLE   rectangle
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor LightBlue
    BorderColor DarkBlue
    FontSize 13
}
skinparam actor {
    BackgroundColor LightYellow
    BorderColor DarkOrange
    FontSize 13
}

title MyAIStorybook FYP-2 — Use Case Diagram

left to right direction

actor "Registered User" as User
actor "System\n(Background)" as Sys

rectangle "MyAIStorybook System" {

    package "Story Generation" {
        usecase "Generate Story\nfrom Text Prompt\n(UC1)" as UC1
        usecase "Generate Story\nfrom Voice Input\n(UC2)" as UC2
        usecase "Generate Personalized\nStory (UC4)" as UC4
    }

    package "Audio Features" {
        usecase "Listen to\nStory Narration\n(UC3)" as UC3
    }

    package "Evaluation & Export" {
        usecase "View Evaluation\nMetrics (UC5)" as UC5
        usecase "Export Story\nto PDF (UC8)" as UC8
    }

    package "Interactive Features" {
        usecase "Chat with\nStory Character\n(UC6)" as UC6
        usecase "Idea Workshop\n(UC7)" as UC7
    }

    package "Background Processing" {
        usecase "Run\nEvaluation Agent\n(Automatic)" as UC_EVAL
    }
}

' User interactions
User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC7

' PDF export included in generation
UC1 .> UC8 : <<include>>
UC4 .> UC8 : <<include>>

' Voice input extends text generation
UC2 .> UC1 : <<extend>>

' Evaluation auto-triggered
UC1 .> UC_EVAL : <<include>>
UC4 .> UC_EVAL : <<include>>
Sys --> UC_EVAL

' Metrics viewable by user
UC_EVAL .> UC5 : <<extend>>

@enduml
